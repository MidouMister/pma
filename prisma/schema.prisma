// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS — match PRD §4 Data Model Enums exactly
// ─────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  USER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE
  READONLY
  SUSPENDED
}

enum ProjectStatus {
  New
  InProgress
  Pause
  Complete
}

enum PhaseStatus {
  TODO
  IN_PROGRESS
  COMPLETE
}

enum SubPhaseStatus {
  TODO
  COMPLETED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum NotificationType {
  INVITATION
  PROJECT
  TASK
  TEAM
  PHASE
  CLIENT
  PRODUCTION
  LANE
  TAG
  GENERAL
}

// ─────────────────────────────────────────────
// CORE ENTITIES
// ─────────────────────────────────────────────

model Plan {
  id                 String         @id @default(cuid())
  // FIX: @unique — two plans with the same name is a data error
  name               String         @unique
  maxUnits           Int?
  maxProjects        Int?
  maxTasksPerProject Int?
  maxMembers         Int?
  // FIX: Decimal instead of Float — financial value, avoids floating-point precision issues
  priceDA            Decimal        @db.Decimal(12, 2)
  subscriptions      Subscription[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Company {
  id                       String         @id @default(cuid())
  name                     String
  // ownerId is the Clerk user ID of the OWNER — unique and immutable (PRD COMP-04)
  ownerId                  String         @unique
  owner                    User           @relation("OwnerCompany", fields: [ownerId], references: [id])
  logo                     String?
  // FIX: @unique — NIF and RC are legal business identifiers, must be globally unique
  NIF                      String         @unique
  RC                       String         @unique
  // NIS and AI are optional but also unique when present
  NIS                      String?        @unique
  AI                       String?        @unique
  formJur                  String
  sector                   String
  wilaya                   String
  address                  String
  phone                    String
  // FIX: @unique — one company per email
  email                    String         @unique
  // Configurable by OWNER only, range 1–100 (PRD BR-15)
  productionAlertThreshold Float          @default(80)
  subscription             Subscription?
  units                    Unit[]
  users                    User[]
  invitations              Invitation[]
  // FIX: Added back-relations for Lane, Task, TimeEntry (were missing FK integrity)
  lanes                    Lane[]
  tasks                    Task[]
  timeEntries              TimeEntry[]
  taskComments             TaskComment[]
  taskMentions             TaskMention[]
  notifications            Notification[]
  activityLogs             ActivityLog[]
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

model Subscription {
  id        String             @id @default(cuid())
  companyId String             @unique
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan               @relation(fields: [planId], references: [id])
  status    SubscriptionStatus
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([companyId])
  @@index([planId])
}

model User {
  id             String         @id @default(cuid())
  clerkId        String         @unique
  name           String
  // FIX: @unique — Clerk syncs one user per email, DB must enforce this
  email          String         @unique
  role           Role
  companyId      String?
  company        Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  unitId         String?
  // FIX: Named relation "UnitMembers" to disambiguate from the "UnitAdmin" relation below
  unit           Unit?          @relation("UnitMembers", fields: [unitId], references: [id], onDelete: SetNull)
  // FIX: Back-relation for Unit.admin (UnitAdmin)
  adminOfUnits   Unit[]         @relation("UnitAdmin")
  ownedCompany   Company?       @relation("OwnerCompany")
  teamMembers    TeamMember[]
  tasks          Task[]
  taskComments   TaskComment[]  @relation("AuthorComments")
  taskMentions   TaskMention[]
  timeEntries    TimeEntry[]
  // FIX: Named relation to disambiguate userId vs targetUserId on Notification
  notifications  Notification[] @relation("UserNotifications")
  targetedNotifs Notification[] @relation("TargetNotifications")
  activityLogs   ActivityLog[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([companyId])
  @@index([unitId])
  @@index([clerkId])
}

model Unit {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // FIX: adminId is nullable — a unit can exist without an admin until the OWNER invites someone with ADMIN role
  adminId       String?
  admin         User?          @relation("UnitAdmin", fields: [adminId], references: [id])
  name          String
  address       String
  phone         String
  email         String
  users         User[]         @relation("UnitMembers")
  invitations   Invitation[]
  clients       Client[]
  projects      Project[]
  lanes         Lane[]
  tasks         Task[]
  tags          Tag[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
  @@index([adminId])
}

model Invitation {
  id        String           @id @default(cuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unitId    String
  unit      Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  email     String
  // NOTE: OWNER role assignment via invitation is forbidden — must be enforced
  // at the Server Action layer with Zod (PRD COMP-03). DB cannot restrict an enum value.
  role      Role
  token     String           @unique
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([email])
  @@index([companyId])
  @@index([unitId])
  @@index([token])
}

// ─────────────────────────────────────────────
// OPERATIONAL ENTITIES
// ─────────────────────────────────────────────

model Client {
  id        String    @id @default(cuid())
  unitId    String
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  companyId String
  name      String
  wilaya    String
  phone     String
  email     String
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Client name and email must be unique within a unit (PRD BR-19)
  @@unique([unitId, name])
  @@unique([unitId, email])
  @@index([unitId])
  @@index([companyId])
}

model Project {
  id           String        @id @default(cuid())
  unitId       String
  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  companyId    String
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  name         String
  code         String
  type         String
  // FIX: Decimal instead of Float — core financial fields (PRD §14 Glossary: HT/TTC)
  montantHT    Decimal       @db.Decimal(15, 2)
  montantTTC   Decimal       @db.Decimal(15, 2)
  ods          DateTime
  // PRD BR-18: deadline stored as two integers, displayed as "X mois Y jours"
  delaiMonths  Int           @default(0)
  delaiDays    Int           @default(0)
  status       ProjectStatus @default(New)
  // FIX: Added progress field — PRD BR-17: weighted average of Phase.progress
  // Recalculated server-side whenever any Phase.progress changes
  progress     Float         @default(0)
  signe        Boolean       @default(false)
  team         Team?
  phases       Phase[]
  ganttMarkers GanttMarker[]
  tasks        Task[]
  timeEntries  TimeEntry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Project code must be unique within a unit
  @@unique([unitId, code])
  @@index([unitId, status])
  @@index([companyId])
  @@index([clientId])
}

model Team {
  id          String       @id @default(cuid())
  projectId   String       @unique
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  teamMembers TeamMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleLabel String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Phase {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  code         String
  // FIX: Decimal — phase budget, must not exceed Project.montantHT (PRD BR-phase budget rule)
  montantHT    Decimal      @db.Decimal(15, 2)
  startDate    DateTime
  endDate      DateTime
  duration     Int // duration in days — derived from startDate/endDate but stored for Gantt performance
  status       PhaseStatus  @default(TODO)
  progress     Float        @default(0)
  observations String?
  subPhases    SubPhase[]
  product      Product?
  tasks        Task[]
  // Shortcut relation for production alert queries (PRD BR-14)
  // Canonical path is Phase → Product → Production; this avoids an extra join
  productions  Production[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([projectId, code])
  @@index([projectId, status])
}

model SubPhase {
  id        String         @id @default(cuid())
  phaseId   String
  phase     Phase          @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  name      String
  code      String
  status    SubPhaseStatus @default(TODO)
  progress  Float          @default(0)
  startDate DateTime
  endDate   DateTime
  tasks     Task[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([phaseId, code])
  @@index([phaseId])
}

model GanttMarker {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  date      DateTime
  className String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Product {
  id          String       @id @default(cuid())
  // One Product per Phase — the planned production baseline
  phaseId     String       @unique
  phase       Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  // taux is a percentage (0–100), Float is appropriate here
  taux        Float
  // FIX: Decimal — mntProd = Phase.montantHT × (taux / 100), PRD §14 Glossary
  montantProd Decimal      @db.Decimal(15, 2)
  date        DateTime
  productions Production[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Production {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  phaseId   String
  phase     Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  // taux is a percentage (0–100), Float is appropriate
  taux      Float
  // FIX: Decimal — actual produced monetary amount
  mntProd   Decimal  @db.Decimal(15, 2)
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([phaseId])
}

// ─────────────────────────────────────────────
// EXECUTION & TRACKING
// ─────────────────────────────────────────────

model Lane {
  id        String   @id @default(cuid())
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  // FIX: Added proper Company relation — was a bare String with no FK integrity
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  order     Int
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
  @@index([companyId])
}

model Task {
  id             String        @id @default(cuid())
  unitId         String
  unit           Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  // FIX: Added proper Company relation — was a bare String with no FK integrity
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // phaseId is required — tasks must belong to a Phase (PRD §10 Task model)
  phaseId        String
  phase          Phase         @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  // subPhaseId is optional — tasks can be at phase or sub-phase level
  subPhaseId     String?
  subPhase       SubPhase?     @relation(fields: [subPhaseId], references: [id], onDelete: SetNull)
  // laneId is nullable — task may exist without a Kanban column
  laneId         String?
  lane           Lane?         @relation(fields: [laneId], references: [id], onDelete: SetNull)
  // PRD BR-16: on user removal, assignedUserId retained (SetNull on membership delete, not here)
  assignedUserId String?
  assignedUser   User?         @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  startDate      DateTime?
  dueDate        DateTime?
  endDate        DateTime?
  complete       Boolean       @default(false)
  order          Int
  tags           TaskTag[]
  comments       TaskComment[]
  timeEntries    TimeEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([unitId])
  @@index([companyId, complete])
  @@index([projectId])
  @@index([phaseId])
  @@index([subPhaseId])
  @@index([laneId])
  @@index([assignedUserId])
}

model Tag {
  id        String    @id @default(cuid())
  unitId    String
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  tasks     TaskTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([unitId, name])
  @@index([unitId])
}

model TaskTag {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

model TaskComment {
  id        String        @id @default(cuid())
  taskId    String
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("AuthorComments", fields: [authorId], references: [id], onDelete: Cascade)
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  body      String
  edited    Boolean       @default(false)
  mentions  TaskMention[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([taskId])
  @@index([authorId])
  @@index([companyId])
}

model TaskMention {
  id              String      @id @default(cuid())
  commentId       String
  comment         TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUserId String
  mentionedUser   User        @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([commentId, mentionedUserId])
  @@index([commentId])
  @@index([mentionedUserId])
  @@index([companyId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  // FIX: Added proper Company relation — was a bare String with no FK integrity
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int? // duration in minutes
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([userId, startTime])
  @@index([projectId])
  @@index([taskId])
}

model Notification {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unitId       String?
  unit         Unit?            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  // FIX: Named relation "UserNotifications" — disambiguates from targetUserId relation
  userId       String?
  user         User?            @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType
  message      String
  read         Boolean          @default(false)
  targetRole   Role?
  // FIX: Added proper relation for targetUserId — was a bare String with no FK integrity
  targetUserId String?
  targetUser   User?            @relation("TargetNotifications", fields: [targetUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([companyId, read, createdAt])
  @@index([unitId])
  @@index([userId, read])
  @@index([targetUserId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unitId     String?
  unit       Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  // FIX: Json? instead of String? — PRD §10 defines metadata as JSON, Prisma has native Json type
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([unitId])
  @@index([userId])
  @@index([entityType, entityId])
}

